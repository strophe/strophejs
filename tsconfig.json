{
  "include": [
      "src/**/*"
  ],
  "compilerOptions": {
    "target": "es2016",
    "module": "esnext",

    // Generate d.ts files
    "declaration": true,
    "declarationMap": true,

    "rootDir": "./src",
    "outDir": "./dist/types/",
    "baseUrl": "./src/",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": false,
    "noImplicitAny": true,
    "strictNullChecks": false,

    "skipLibCheck": true,

    "moduleResolution": "node",
    "resolveJsonModule": true,

    "lib": ["ES2020", "DOM", "DOM.Iterable"]
  }
}
